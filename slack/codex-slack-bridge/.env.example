# Slack App tokens. See slack-app-manifest.yaml and README.md.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Exactly one Slack member ID is allowed to control this bridge.
SLACK_ALLOWED_USER_ID=U0XXXXXXXXX

# Local repository operated by Codex. Keep the deployed bridge outside this tree.
CODEX_CWD=/absolute/path/to/target-repository
CODEX_BIN=codex

# Safe default: Codex may edit CODEX_CWD but cannot ask for interactive approvals.
# Other values: read-only, danger-full-access (strongly discouraged).
CODEX_SANDBOX=workspace-write

# Explicit bridge defaults; these override ~/.codex/config.toml.
CODEX_MODEL=gpt-5.6-sol
CODEX_PROFILE=
CODEX_REASONING_EFFORT=ultra
CODEX_SERVICE_TIER=fast
CODEX_FAST_MODE=true

# Optional extra writable roots, separated with ':' on Linux.
CODEX_ADD_DIRS=
CODEX_SKIP_GIT_REPO_CHECK=false
CODEX_STRICT_CONFIG=false

# Leave false. Setting true acknowledges that Codex can rewrite bridge/state/credentials
# and have modified code executed by the supervisor after restart.
BRIDGE_ALLOW_UNSAFE_SELF_HOSTING=false

# 0 disables the timeout.
CODEX_TURN_TIMEOUT_SECONDS=3600
CODEX_INTERRUPT_GRACE_SECONDS=8

# Tool details can contain paths or commands. Keep this false unless needed.
CODEX_SHOW_TOOL_DETAILS=false
# Keep replies inside Slack AI App/New Chat threads when a thread_ts is present.
SLACK_REPLY_IN_THREAD=true

BRIDGE_MAX_PROMPT_CHARS=20000
BRIDGE_MAX_QUEUE_SIZE=100
BRIDGE_PROGRESS_INTERVAL_SECONDS=1.5
BRIDGE_LOG_LEVEL=INFO

# Slack attachments are streamed into the private state directory. Codex receives
# their absolute local paths. Limits are enforced against metadata and bytes read.
BRIDGE_MAX_FILES_PER_MESSAGE=10
BRIDGE_MAX_FILE_BYTES=52428800
BRIDGE_DOWNLOAD_TIMEOUT_SECONDS=60

# Runtime state defaults to ./state. Prefer a private, persistent filesystem.
# BRIDGE_STATE_DIR=/private/path/codex-slack-bridge-state
# BRIDGE_UPLOAD_DIR=/private/path/codex-slack-bridge-uploads

# Optional Slurm settings used by keepalive.sh.
SLURM_ACCOUNT=nvr_lpr_llm
SLURM_PARTITION=cpu_long
SLURM_TIME=5-00:00:00
SLURM_CPUS=4
SLURM_MEMORY=16G
# Reuse an existing long-running job when node quota is full; otherwise sbatch.
SLURM_ATTACH_TO_EXISTING_JOB=true
SLURM_ATTACH_MIN_SECONDS=3600
