# Slack App 的两个 token（创建 app 后获取，见 slack-app-manifest.yaml）
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# 你自己的 Slack member ID（Slack 个人资料 -> 三个点 -> Copy member ID，形如 U0XXXXXXXXX）
# 只有这个用户的 DM 会被处理
SLACK_ALLOWED_USER_ID=U0XXXXXXXXX

# Claude Code 的工作目录。部署 bridge 时请保持它位于该目录之外。
CLAUDE_CWD=/absolute/path/to/target-repository

# bypassPermissions = YOLO 全权限（等价 --dangerously-skip-permissions）
# 稳妥一点可改成 acceptEdits（自动批准文件编辑，危险命令仍会被拦截）
CLAUDE_PERMISSION_MODE=bypassPermissions

# 模型与推理强度，默认与 ~/.zshrc 里的 claude() 包装一致，不填即可
#CLAUDE_MODEL=claude-fable-5
#CLAUDE_EFFORT=xhigh
#CLAUDE_SETTINGS={"ultracode": true}
